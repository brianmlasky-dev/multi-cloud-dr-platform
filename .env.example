# ─────────────────────────────────────────────────────────────────────────────
# Crestline Financial DR Platform — Environment Variables Reference
# Copy this file to .env and fill in values before running any scripts.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloud Provider Selection ─────────────────────────────────────────────────
# Tells the app which cloud it is running on. Used by the status dashboard.
# Values: aws | gcp
CLOUD_PROVIDER=aws

# ── Environment Label ────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# Route 53 hosted zone ID for the crestlinefinancial.com domain.
# Obtain with: aws route53 list-hosted-zones
ROUTE53_HOSTED_ZONE_ID=ZXXXXXXXXXXXXXXXXXX

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=multi-cloud-dr-platform
GCP_REGION=us-central1

# Static IP of the GCP standby Cloud Run service.
# Required for gcp-to-aws failback to restore the Route 53 record.
# Obtain with: gcloud compute addresses list
GCP_STANDBY_IP=34.x.x.x

# ── Database — AWS RDS ───────────────────────────────────────────────────────
RDS_HOST=multi-cloud-dr.xxxxxxxxxx.us-east-1.rds.amazonaws.com
RDS_USER=crestline_admin
RDS_PASSWORD=<replace-with-secret-manager-value>
RDS_DB_NAME=crestline_db

# S3 bucket used to stage pg_dump files for cross-cloud transfer.
S3_BUCKET=multi-cloud-dr-app-storage

# ── Database — GCP Cloud SQL ─────────────────────────────────────────────────
# Connection name format: <project>:<region>:<instance>
CLOUD_SQL_INSTANCE=multi-cloud-dr-platform:us-central1:multi-cloud-dr-postgres
CLOUD_SQL_USER=crestline_admin
CLOUD_SQL_PASSWORD=<replace-with-secret-manager-value>
CLOUD_SQL_DB_NAME=crestline_db

# GCS bucket used to receive the dump file transferred from S3.
GCS_BUCKET=multi-cloud-dr-dr-storage
